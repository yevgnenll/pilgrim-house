# Notion API
# Notion Integration에서 발급받은 토큰
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 데이터베이스 ID (각 DB URL에서 복사)
# 예: https://notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx?v=...
#                        ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ 이 부분
NOTION_PRAYER_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_GALLERY_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_NEWS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (https://supabase.com/dashboard/project/_/settings/api 에서 확인)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
